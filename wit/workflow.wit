// The ONLY contract between engine and guests (SPEC.md §4 + Tasks 2.1, 3.1).
// 0.2.0 added await-event (a new import — non-breaking once guests rebuilt).
// 0.3.0 added checkpoint + the resume EXPORT — a BREAKING change: every guest must
// implement resume (a stub `Err("no checkpoints")` suffices) and be rebuilt.
// 0.4.0 (v1.2) added http-request, kv-get, kv-set — new imports only; guests
// need a rebuild, their source is untouched. (0.x minors are still blob-
// incompatible: components compiled against 0.3.0 will not instantiate.)
// 0.5.0 (v2.1) added secret + a timeout-ms parameter on http-request. The
// http-request signature change means guests that call it must add the new
// argument (0 = engine default) when rebuilding.
// 0.6.0 (v2.2) added provider-call — a new import only; rebuild suffices.
// 0.7.0 (micro-cloud phase 4) added `interface platform-api` and two NEW
// worlds — `handler` (stateless serverless functions) and `solver`
// (import-free judge submissions). `world workflow` is textually unchanged:
// workflow guests rebuild against 0.7.0 without source changes.
// Never edit an interface in place mid-phase.
package keel:workflow@0.7.0;

interface host-api {
    /// v1.2 — http-request's result. status is the raw code (2xx not special);
    /// headers are response headers as received (name, value) pairs.
    record http-response {
        status: u16,
        headers: list<tuple<string, string>>,
        body: string,
    }

    /// v1.2 — the general journaled HTTP call. Unlike http-get, a non-2xx
    /// status is NOT an error: the response comes back whatever the status,
    /// and only transport failures are `err`. `retry-attempts` (0 = none)
    /// opts into retrying transport errors and 5xx — the caller decides,
    /// because auto-retrying a non-idempotent POST is not the engine's call.
    /// Response bodies are utf-8, truncated by the host to 1 MiB.
    /// v2.1 — `timeout-ms` caps EACH attempt (0 = the engine default, 30s).
    /// A timeout is a transport failure: `err` (and retried if opted in).
    http-request: func(
        method: string,
        url: string,
        headers: list<tuple<string, string>>,
        body: option<string>,
        retry-attempts: u32,
        timeout-ms: u32,
    ) -> result<http-response, string>;

    /// v2.1 — read a named secret from the engine's --secrets-file. The VALUE
    /// never touches the journal or database: the journal records only the
    /// name and a salted sha256, and replay re-reads the live file and
    /// verifies the hash — a secret rotated mid-workflow fails replay loudly
    /// (restore the old value or cancel the workflow) instead of silently
    /// diverging. Values of secrets read this way are also redacted from
    /// journaled http-request/http-get requests ({{secret:name}} placeholder).
    /// `err` when no secrets file is configured or the name is absent.
    secret: func(name: string) -> result<string, string>;

    /// Journaled HTTP GET. ok = response body (utf-8, truncated by host to 1 MiB),
    /// err = human-readable error string. Non-2xx status is an err.
    http-get: func(url: string) -> result<string, string>;

    /// Journaled durable sleep.
    sleep-ms: func(ms: u64);

    /// Journaled wall-clock time, unix epoch milliseconds.
    now-ms: func() -> u64;

    /// Journaled pseudo-randomness.
    random-u64: func() -> u64;

    /// Journaled. Blocks until an event with this name is delivered to the workflow
    /// via POST /api/workflows/:id/events. Returns the event payload (JSON string).
    await-event: func(name: string) -> string;

    /// Journaled. The guest hands the engine a self-serialized state blob at a safe
    /// point. Contract: state must fully determine all FUTURE host calls the guest
    /// will make (given replayed results). The engine may later restart the guest
    /// via resume(state) instead of run(input), and prunes journal rows older than
    /// the checkpoint.
    checkpoint: func(state: list<u8>);

    /// v1.2 — journaled durable KV, scoped to this workflow. State that must
    /// survive crashes without checkpoint gymnastics. Values live until the
    /// workflow is garbage-collected.
    kv-set: func(key: string, value: string);

    /// v1.2 — journaled read of this workflow's KV. `none` if never set.
    kv-get: func(key: string) -> option<string>;

    /// v2.2 — call a capability provider registered on the engine
    /// (--provider name=path.wasm; a wasm component implementing the
    /// keel:provider world — see PROVIDERS.md). Journaled as
    /// custom:<name>:<kind>; replay returns the recorded response without
    /// re-invoking the provider. Unknown name/kind, provider traps and blown
    /// budgets come back as err (data). Secret values you read are redacted
    /// from the journaled request, like http-request.
    provider-call: func(name: string, kind: string, request: string) -> result<string, string>;

    /// NOT journaled as an effect: forwarded to engine logs, tagged with the
    /// workflow id. Free to call; returns nothing; identical on replay by
    /// construction (log is simply not sequence-numbered at all — see SPEC.md §4.1).
    log: func(msg: string);
}

/// Phase 4 (micro-cloud) — the FUNCTION host surface. Everything here is
/// DIRECT, not journaled: functions are stateless and non-durable on purpose
/// (no journal, no replay, real now/random). Durability lives one door over —
/// a function that needs reliability calls start-workflow.
interface platform-api {
    /// Forwarded to engine logs with a `fn:` prefix. Not metered.
    log: func(msg: string);

    /// Real wall clock, unix epoch milliseconds. Direct (functions replay never).
    now-ms: func() -> u64;

    /// Real randomness. Direct.
    random-u64: func() -> u64;

    /// Start a durable workflow (base-spec semantics: the row commits before
    /// the spawn). Returns the workflow id; err = unknown module hash.
    start-workflow: func(module-hash: string, input: string) -> result<string, string>;

    /// Fetch a workflow as a JSON string — the same shape as
    /// GET /api/workflows/:id ({"id","status","output",...}). err = unknown id.
    get-workflow: func(id: string) -> result<string, string>;
}

world workflow {
    import host-api;

    /// Entry point. input/output are JSON strings (engine treats them as opaque).
    export run: func(input: string) -> result<string, string>;

    /// Continue from a checkpointed state blob. Guests that never call checkpoint
    /// implement this as: return Err("no checkpoints").
    export resume: func(state: list<u8>) -> result<string, string>;
}

/// Phase 4 (micro-cloud) — a stateless serverless function: fresh sandboxed
/// instance per request, fuel/epoch/memory quotas from the bound route.
world handler {
    import platform-api;

    /// The request as the host hands it over. `path` is the part AFTER the
    /// route prefix (always starts with "/"); `query` is the raw query string
    /// (may be ""); the host caps `body` at 10 MiB before invoking.
    record http-request {
        method: string,
        path: string,
        query: string,
        headers: list<tuple<string, string>>,
        body: list<u8>,
    }

    record http-response {
        status: u16,
        headers: list<tuple<string, string>>,
        body: list<u8>,
    }

    export handle: func(req: http-request) -> http-response;
}

/// Phase 5 (micro-cloud) — a judge submission. NO imports at all: solvers are
/// pure compute, the tightest sandbox in the platform — the module cannot
/// name a single external capability.
world solver {
    export solve: func(input: string) -> result<string, string>;
}
